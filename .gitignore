# Visual Studio 2015 user specific files
Sentinels_ListenServer/.vs/
Sentinels/.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
Sentinels_ListenServer/SourceArt/**/*.png
Sentinels_ListenServer/SourceArt/**/*.tga
Sentinels/SourceArt/**/*.png
Sentinels/SourceArt/**/*.tga

# Binary Files
Sentinels_ListenServer/Binaries/*
Sentinels_ListenServer/Plugins/*/Binaries/*
Sentinels/Binaries/*
Sentinels/Plugins/*/Binaries/*

# Builds
Sentinels_ListenServer/Build/*
Sentinels/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Sentinels_ListenServer/Build/*/
Sentinels_ListenServer/Build/*/**
!Sentinels_ListenServer/Build/*/PakBlacklist*.txt
!Sentinels/Build/*/
Sentinels/Build/*/**
!Sentinels/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Sentinels_ListenServer/Build/**/*.ico
!Sentinels/Build/**/*.ico


# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Sentinels_ListenServer/Saved/*
Sentinels/Saved/*

# Compiled source files for the engine to use
Sentinels_ListenServer/Intermediate/*
Sentinels_ListenServer/Plugins/*/Intermediate/*
Sentinels_ListenServer/Plugins/*
Sentinels/Intermediate/*
Sentinels/Plugins/*/Intermediate/*
Sentinels/Plugins/*

# Cache files for the editor to use
Sentinels_ListenServer/DerivedDataCache/*
Sentinels_ListenServer/Packaged/*
Sentinels/DerivedDataCache/*
Sentinels/Packaged/*